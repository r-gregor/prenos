# vim filename, but create filename-backup first
vimb() {
	if [ $# -ne 1 ]; then
		vim
	else
		local fname="$1"
		if [ ! -f "${fname}" ]; then
			echo "[ERROR] no such file"
			exit 1
		fi

		if [ -f "${fname}-backup" ]; then
			echo "[INFO] backup file already exists"
			vim "${fname}"
		else
			cp -v "${fname}" "${fname}-backup"
			vim "${fname}"
		fi
	fi
}

